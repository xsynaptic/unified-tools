{
  "name": "@xsynaptic/unified-tools",
  "version": "4.2.1",
  "description": "A common set of tools for transforming and manipulating markup and text",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build-tsc": "tsc --build",
    "check-types": "tsc --project tsconfig.json --noemit",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix && tsc --noEmit --extendedDiagnostics",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsynaptic/unified-tools.git"
  },
  "keywords": [
    "unified",
    "rehype",
    "rehype-plugin",
    "remark",
    "remark-plugin"
  ],
  "author": "Alexander Synaptic <x@synapticism.com>",
  "bugs": {
    "url": "https://github.com/xsynaptic/unified-tools/issues"
  },
  "homepage": "https://github.com/xsynaptic/unified-tools#readme",
  "license": "MIT",
  "dependencies": {
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "rehype-wrap-cjk": "^2.1.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "retext": "^9.0.0",
    "retext-smartypants": "^6.2.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "ohash": "^2.0.11",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
