{
  "name": "@xsynaptic/unified-tools",
  "version": "3.0.2",
  "description": "A common set of tools for transforming and manipulating markup and text",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build-tsc": "tsc --build",
    "check-types": "tsc --project tsconfig.json --noemit",
    "lint": "eslint",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsynaptic/unified-tools.git"
  },
  "keywords": [
    "unified",
    "rehype",
    "rehype-plugin",
    "remark",
    "remark-plugin"
  ],
  "author": "Alexander Synaptic <x@synapticism.com>",
  "bugs": {
    "url": "https://github.com/xsynaptic/unified-tools/issues"
  },
  "homepage": "https://github.com/xsynaptic/unified-tools#readme",
  "license": "MIT",
  "dependencies": {
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "rehype-wrap-cjk": "^1.0.10",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "retext": "^9.0.0",
    "retext-smartypants": "^6.2.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "ohash": "^2.0.11",
    "prettier": "^3.8.1",
    "tsdown": "^0.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
